{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Markd",
  "version": "0.3.1",
  "identifier": "com.markd.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Markd",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Text Document",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/INCATO-ai/markd/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFMzBFMzk5MTZENzZFODMKUldTRGJ0Y1dtZU13SGpjcWR2SzhqQTV2RnhlNmxGK3NsWlgrWUhOaWI0V016cFVTVThyaTRlMGIK"
    }
  }
}
